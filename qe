function MusicPlayer:_startVisualizer()
    local conn = RunService.Heartbeat:Connect(function()
        if not self._sound or not self._isPlaying then
            for _, bar in ipairs(self._visualizerBars) do
                if bar and bar.Parent then
                    Aether.Tween(bar, 0.1, nil, nil, {Size = UDim2.new(0, 6, 0, 2)})
                end
            end
            return
        end
        local loudness = self._sound.PlaybackLoudness or 0
        for i, bar in ipairs(self._visualizerBars) do
            if bar and bar.Parent then
                local height = math.clamp((loudness / 500) * math.random(60, 140) + 3, 2, 150)
                Aether.Tween(bar, 0.05, nil, nil, {Size = UDim2.new(0, 6, 0, height)})
            end
        end
    end)
    table.insert(self._connections, conn)
end

function MusicPlayer:AddTrack(name, artist, soundId)
    table.insert(self._playlist, {Name = name, Artist = artist, SoundId = soundId})
    local index = #self._playlist

    local btn = New("TextButton", {
        BackgroundColor3 = C.Surface,
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        Size = UDim2.new(1, -8, 0, 26),
        Position = UDim2.new(0, 4, 0, 0),
        Font = Enum.Font.Gotham,
        Text = "  " .. name .. " — " .. artist,
        TextColor3 = C.TextSecondary,
        TextSize = 11,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 17,
        AutoButtonColor = false,
    }, self._playlistFrame)

    btn.MouseEnter:Connect(function() Aether.Tween(btn, 0.15, nil, nil, {BackgroundTransparency = 0.5}) end)
    btn.MouseLeave:Connect(function() Aether.Tween(btn, 0.15, nil, nil, {BackgroundTransparency = 1}) end)
    btn.MouseButton1Click:Connect(function() self:LoadTrack(index) end)

    self._playlistFrame.CanvasSize = UDim2.new(0, 0, 0, #self._playlist * 27)
end

function MusicPlayer:LoadTrack(index)
    self._currentTrack = index
    local track = self._playlist[index]
    if not track then return end

    self._trackTitle.Text = track.Name
    self._trackArtist.Text = track.Artist

    if self._sound then self._sound:Destroy() end

    self._sound = Instance.new("Sound")
    self._sound.Parent = SoundService
    self._sound.SoundId = track.SoundId
    self._sound.Volume = 0.5

    self._sound.Ended:Connect(function() self:Next() end)

    task.spawn(function()
        while self._sound and self._sound.Parent do
            if self._sound.IsPlaying then
                local current = math.floor(self._sound.TimePosition)
                local total = math.floor(self._sound.TimeLength)
                if total > 0 then
                    self._progressFill.Size = UDim2.new(current / total, 0, 1, 0)
                    self._timeLabel.Text = string.format("%d:%02d / %d:%02d", math.floor(current/60), current%60, math.floor(total/60), total%60)
                end
            end
            task.wait(0.1)
        end
    end)

    self:Play()
end

function MusicPlayer:Play()
    if self._sound then
        self._sound:Play()
        self._isPlaying = true
        self._playBtn.Text = "⏸"
    end
end

function MusicPlayer:Pause()
    if self._sound then
        self._sound:Pause()
        self._isPlaying = false
        self._playBtn.Text = "▶"
    end
end

function MusicPlayer:Stop()
    if self._sound then
        self._sound:Stop()
        self._isPlaying = false
        self._playBtn.Text = "▶"
        self._progressFill.Size = UDim2.new(0, 0, 1, 0)
        self._timeLabel.Text = "0:00 / 0:00"
    end
end

function MusicPlayer:TogglePlay()
    if self._isPlaying then self:Pause() else self:Play() end
end

function MusicPlayer:Next()
    if #self._playlist == 0 then return end
    local next = self._currentTrack + 1
    if next > #self._playlist then next = 1 end
    self:LoadTrack(next)
end

function MusicPlayer:Previous()
    if #self._playlist == 0 then return end
    local prev = self._currentTrack - 1
    if prev < 1 then prev = #self._playlist end
    self:LoadTrack(prev)
end

function MusicPlayer:Destroy()
    for _, conn in ipairs(self._connections) do conn:Disconnect() end
    if self._sound then self._sound:Destroy() end
    if self._frame then self._frame:Destroy() end
end

