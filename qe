    end)
    entry.MouseLeave:Connect(function()
        Aether.Tween(entry, 0.15, nil, nil, {BackgroundTransparency = 1})
        entry.TextColor3 = C.TextSecondary
    end)
    entry.MouseButton1Click:Connect(function()
        if isDir then
            self:Refresh(fullPath)
        else
            if readfile then
                local ok, content = pcall(readfile, fullPath)
                if ok then print("[FileBrowser] Read:", fullPath, "Size:", #content) end
            end
        end
    end)
end

function FileBrowser:Refresh(path)
    self._currentPath = path or ""
    self._pathText.Text = #self._currentPath > 0 and self._currentPath or "workspace/"

    for _, child in ipairs(self._fileList:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end

    if #self._currentPath > 0 then
        local parentPath = self._currentPath:match("^(.*)[/\\]") or ""
        self:_addEntry("..", true, parentPath)
    end

    if listfiles then
        local success, files = pcall(listfiles, self._currentPath)
        if success and files then
            table.sort(files)
            for _, file in ipairs(files) do
                local name = file:match("([^/\\]+)$") or file
                local isDir = false
                local dirTest = pcall(listfiles, file)
                if dirTest then isDir = true end
                self:_addEntry(name, isDir, file)
            end
            self._fileList.CanvasSize = UDim2.new(0, 0, 0, (#files + 1) * 29 + 8)
        end
    else
        New("TextLabel", {
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 60),
            Font = Enum.Font.Gotham,
            Text = "listfiles() not available\nUse a supported executor (Synapse, KRNL, Fluxus)",
            TextColor3 = C.TextMuted,
            TextSize = 11,
            TextWrapped = true,
            ZIndex = 17,
        }, self._fileList)
    end
end

function FileBrowser:Destroy()
    if self._frame then self._frame:Destroy() end
end

