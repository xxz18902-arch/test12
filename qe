function Elements.Toggle(parent, text, callback)
    callback = callback or function() end
    local toggled = false
    local interacting = false

    local frame = New("Frame", {
        Name = text .. "Toggle",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 32),
        ZIndex = 15,
    }, parent)

    local label = New("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -60, 1, 0),
        Font = Enum.Font.Gotham,
        Text = text,
        TextColor3 = C.TextPrimary,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 16,
    }, frame)

    local track = New("Frame", {
        BackgroundColor3 = C.Border,
        BorderSizePixel = 0,
        Position = UDim2.new(1, -52, 0.5, -10),
        Size = UDim2.new(0, 44, 0, 20),
        ZIndex = 16,
    }, frame)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, track)

    local circle = New("Frame", {
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0,
        Position = UDim2.new(0, 2, 0.5, -8),
        Size = UDim2.new(0, 16, 0, 16),
        ZIndex = 17,
    }, track)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, circle)

    local clickArea = New("TextButton", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Text = "",
        ZIndex = 18,
    }, frame)

    local function setState(state)
        if interacting then return end
        interacting = true
        toggled = state
        local dur = 0.2

        if toggled then
            Aether.Tween(track, dur, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {BackgroundColor3 = C.Success})
            Aether.Tween(circle, dur, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {Position = UDim2.new(1, -18, 0.5, -8)})
            Aether.Tween(label, dur, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {TextColor3 = C.Success})
        else
            Aether.Tween(track, dur, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {BackgroundColor3 = C.Border})
            Aether.Tween(circle, dur, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {Position = UDim2.new(0, 2, 0.5, -8)})
            Aether.Tween(label, dur, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, {TextColor3 = C.TextPrimary})
        end

        task.delay(dur, function() interacting = false end)
        pcall(callback, toggled)
    end

    clickArea.MouseButton1Click:Connect(function() setState(not toggled) end)
    return {Set = setState, Get = function() return toggled end, Frame = frame}
end

function Elements.Slider(parent, text, min, max, default, callback)
    min, max, default = min or 0, max or 100, default or min or 0
    callback = callback or function() end
    local dragging = false

    local frame = New("Frame", {
        Name = text .. "Slider",
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 48),
        ZIndex = 15,
    }, parent)

    New("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(0.55, 0, 0, 20),
        Font = Enum.Font.Gotham,
        Text = text,
        TextColor3 = C.TextPrimary,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 16,
    }, frame)

    local valueBox = New("TextBox", {
        BackgroundColor3 = C.Background,
        BorderSizePixel = 0,
        Position = UDim2.new(1, -55, 0, 0),
        Size = UDim2.new(0, 50, 0, 20),
        Font = Enum.Font.Gotham,
        Text = tostring(default),
        TextColor3 = C.TextPrimary,
        TextSize = 12,
        ClearTextOnFocus = false,
        ZIndex = 16,
    }, frame)
    New("UICorner", { CornerRadius = UDim.new(0, 4) }, valueBox)
    local boxStroke = New("UIStroke", { Color = C.Border, Thickness = 1 }, valueBox)

    local track = New("Frame", {
        BackgroundColor3 = C.Border,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 32),
        Size = UDim2.new(1, 0, 0, 4),
        ZIndex = 16,
    }, frame)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, track)

    local fill = New("Frame", {
        BackgroundColor3 = C.AccentOrange,
        BorderSizePixel = 0,
        Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
        ZIndex = 17,
    }, track)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, fill)

    local thumb = New("Frame", {
        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
        BorderSizePixel = 0,
        Position = UDim2.new((default - min) / (max - min), -7, 0.5, -7),
        Size = UDim2.new(0, 14, 0, 14),
        ZIndex = 18,
    }, track)
    New("UICorner", { CornerRadius = UDim.new(1, 0) }, thumb)
    New("UIStroke", { Color = C.AccentOrange, Thickness = 2.5 }, thumb)

    local function updateFromInput(input)
        local scale = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local value = math.floor(scale * (max - min) + min)
        fill.Size = UDim2.new(scale, 0, 1, 0)
        thumb.Position = UDim2.new(scale, -7, 0.5, -7)
        valueBox.Text = tostring(value)
        pcall(callback, value)
    end

    thumb.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then updateFromInput(input) end
    end)
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then updateFromInput(input) end
    end)
    valueBox.Focused:Connect(function() Aether.Tween(boxStroke, 0.2, nil, nil, {Color = C.AccentOrange}) end)
    valueBox.FocusLost:Connect(function()
        Aether.Tween(boxStroke, 0.2, nil, nil, {Color = C.Border})
        local num = math.clamp(tonumber(valueBox.Text) or default, min, max)
        local scale = (num - min) / (max - min)
        fill.Size = UDim2.new(scale, 0, 1, 0)
        thumb.Position = UDim2.new(scale, -7, 0.5, -7)
        valueBox.Text = tostring(num)
        pcall(callback, num)
    end)

    return {Set = function(v)
        v = math.clamp(v, min, max)
        local scale = (v - min) / (max - min)
        fill.Size = UDim2.new(scale, 0, 1, 0)
        thumb.Position = UDim2.new(scale, -7, 0.5, -7)
        valueBox.Text = tostring(v)
    end, Get = function() return tonumber(valueBox.Text) or default end, Frame = frame}
end

