        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 11,
    }, topbar)

    local controls = New("Frame", {
        Name = "Controls",
        Position = UDim2.new(1, -90, 0, 0),
        Size = UDim2.new(0, 90, 1, 0),
        BackgroundTransparency = 1,
        ZIndex = 11,
    }, topbar)

    local function makeWinBtn(text, pos, color, callback)
        local btn = New("TextButton", {
            Position = UDim2.new(0, pos, 0.5, -10),
            Size = UDim2.new(0, 20, 0, 20),
            BackgroundTransparency = 1,
            Text = text,
            TextColor3 = C.TextSecondary,
            Font = Enum.Font.GothamBold,
            TextSize = 14,
            ZIndex = 12,
        }, controls)
        btn.MouseEnter:Connect(function() Aether.TweenHover(btn, {TextColor3 = color}) end)
        btn.MouseLeave:Connect(function() Aether.TweenHover(btn, {TextColor3 = C.TextSecondary}) end)
        btn.MouseButton1Click:Connect(callback)
        return btn
    end

    makeWinBtn("—", 0, C.Warning, function() self:Minimize() end)
    makeWinBtn("□", 28, C.Success, function() end)
    makeWinBtn("✕", 56, C.Danger, function() self:Destroy() end)

    self._topbar = topbar
end

