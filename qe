function Aether:_buildStatusBar()
    local bar = New("Frame", {
        Name = "StatusBar",
        Position = UDim2.new(0, 0, 1, -25),
        Size = UDim2.new(1, 0, 0, 25),
        BackgroundColor3 = C.Surface,
        BorderSizePixel = 0,
        ZIndex = 10,
    }, self._main)
    New("UICorner", { CornerRadius = UDim.new(0, 8) }, bar)
    New("Frame", { Size = UDim2.new(1, 0, 0, 8), BackgroundColor3 = C.Surface, BorderSizePixel = 0, ZIndex = 10 }, bar)
    New("UIStroke", { Color = C.Border, Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border }, bar)

    self._statusLabel = New("TextLabel", {
        Name = "StatusText",
        Position = UDim2.new(0, 12, 0, 0),
        Size = UDim2.new(0.5, 0, 1, 0),
        BackgroundTransparency = 1,
        Text = "● Ready",
        TextColor3 = C.Success,
        Font = Enum.Font.Gotham,
        TextSize = 10,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 11,
    }, bar)

    self._fpsLabel = New("TextLabel", {
        Name = "FPS",
        Position = UDim2.new(0.5, 0, 0, 0),
        Size = UDim2.new(0.5, -12, 1, 0),
        BackgroundTransparency = 1,
        Text = "60 FPS",
        TextColor3 = C.TextMuted,
        Font = Enum.Font.Code,
        TextSize = 10,
        TextXAlignment = Enum.TextXAlignment.Right,
        ZIndex = 11,
    }, bar)

    local lastTime = tick()
    local frameCount = 0
    table.insert(self._connections, RunService.Heartbeat:Connect(function()
        frameCount += 1
        local now = tick()
        if now - lastTime >= 1 then
            if self._fpsLabel and self._fpsLabel.Parent then
                self._fpsLabel.Text = math.round(frameCount / (now - lastTime)) .. " FPS"
            end
            frameCount = 0
            lastTime = now
        end
    end))
end

function Aether:_setupDrag()
    local dragging, dragStart, startPos
    local topbar = self._topbar
    local main = self._main

    topbar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = main.Position
        end
    end)

    topbar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    table.insert(self._connections, UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            main.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end))
end

function Aether:_setupToggleKey()
    table.insert(self._connections, UserInputService.InputBegan:Connect(function(input, gpe)
        if gpe then return end
        if UserInputService:GetFocusedTextBox() then return end
        if input.KeyCode == self._toggleKey then
            self:Toggle()
        end
    end))
end

function Aether:_playIntro()
    local main = self._main
    local backdrop = self._backdrop
    local shadow = self._shadow
    main.Size = UDim2.new(0, 900 * 0.8, 0, 580 * 0.8)
    main.BackgroundTransparency = 1
    backdrop.BackgroundTransparency = 1
    shadow.ImageTransparency = 1

    Aether.Tween(backdrop, 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, { BackgroundTransparency = 0.6 })
    Aether.Tween(shadow, 0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, { ImageTransparency = 0.4 })
    Aether.Tween(main, 0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out, {
        Size = UDim2.new(0, 900, 0, 580),
        BackgroundTransparency = 0,
    })
end

-- ── Add Page ─────────────────────────────────────────────────────────────────
function Aether:AddPage(name, icon)
    local pageCount = #self._pages + 1

    local btn = New("TextButton", {
        Name = "Nav_" .. name,
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundColor3 = C.Surface,
        BackgroundTransparency = 1,
        Text = "",
        BorderSizePixel = 0,
        LayoutOrder = pageCount,
        ZIndex = 7,
    }, self._navList)

    local indicator = New("Frame", {
        Name = "Indicator",
        Size = UDim2.new(0, 3, 0, 0),
        Position = UDim2.new(0, 0, 0.5, 0),
        AnchorPoint = Vector2.new(0, 0.5),
        BackgroundColor3 = C.AccentOrange,
        BorderSizePixel = 0,
        ZIndex = 8,
    }, btn)

    New("TextLabel", {
        Name = "Icon",
        Position = UDim2.new(0, 14, 0, 0),
        Size = UDim2.new(0, 20, 1, 0),
        BackgroundTransparency = 1,
        Text = icon or "◈",
        TextColor3 = C.TextSecondary,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        ZIndex = 8,
    }, btn)

    local label = New("TextLabel", {
        Name = "Label",
        Position = UDim2.new(0, 42, 0, 0),
        Size = UDim2.new(1, -42, 1, 0),
        BackgroundTransparency = 1,
        Text = name,
        TextColor3 = C.TextSecondary,
        Font = Enum.Font.Gotham,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left,
        ZIndex = 8,
    }, btn)

    local page = New("ScrollingFrame", {
        Name = "Page_" .. name,
        Size = UDim2.fromScale(1, 1),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 4,
        ScrollBarImageColor3 = C.Border,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false,
        ZIndex = 6,
    }, self._pagesFrame)

    New("UIPadding", {
        PaddingTop = UDim.new(0, 12),
        PaddingLeft = UDim.new(0, 14),
        PaddingRight = UDim.new(0, 14),
        PaddingBottom = UDim.new(0, 12),
    }, page)

    New("UIListLayout", {
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 10),
    }, page)

    local pageData = { name = name, frame = page, btn = btn, indicator = indicator, label = label }
    table.insert(self._pages, pageData)

    btn.MouseEnter:Connect(function()
        if self._activePage ~= pageData then
            Aether.TweenHover(btn, { BackgroundTransparency = 0.5 })
            Aether.TweenHover(label, { TextColor3 = C.TextPrimary })
        end
    end)
    btn.MouseLeave:Connect(function()
        if self._activePage ~= pageData then
            Aether.TweenHover(btn, { BackgroundTransparency = 1 })
            Aether.TweenHover(label, { TextColor3 = C.TextSecondary })
        end
    end)

    btn.MouseButton1Click:Connect(function()
        self:SelectPage(pageData)
    end)

    if pageCount == 1 then
        self:SelectPage(pageData)
    end

    return page
end

function Aether:SelectPage(pageData)
    if self._activePage then
        local prev = self._activePage
        prev.frame.Visible = false
        Aether.TweenHover(prev.btn, { BackgroundTransparency = 1 })
        Aether.TweenHover(prev.label, { TextColor3 = C.TextSecondary })
        Aether.TweenHover(prev.indicator, { Size = UDim2.new(0, 3, 0, 0) })
        local prevIcon = prev.btn:FindFirstChild("Icon")
        if prevIcon then Aether.TweenHover(prevIcon, { TextColor3 = C.TextSecondary }) end
    end

    self._activePage = pageData
    pageData.frame.Visible = true
    Aether.TweenHover(pageData.btn, { BackgroundTransparency = 0.3 })
    Aether.TweenHover(pageData.label, { TextColor3 = C.TextPrimary })
    Aether.TweenHover(pageData.indicator, { Size = UDim2.new(0, 3, 1, 0) })
    local icon = pageData.btn:FindFirstChild("Icon")
    if icon then Aether.TweenHover(icon, { TextColor3 = C.AccentOrange }) end

    self:SetStatus("Tab: " .. pageData.name, C.TextSecondary)
end

-- ── Utilities ──────────────────────────────────────────────────────────────
function Aether:SetStatus(text, color)
    if self._statusLabel then
        self._statusLabel.Text = "● " .. text
        self._statusLabel.TextColor3 = color or C.Success
    end
end

function Aether:Minimize()
    if not self._isVisible then return end
    self._isVisible = false

    local main = self._main
    local backdrop = self._backdrop
    local shadow = self._shadow

    self._savedPosition = main.Position

    Aether.Tween(main, 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, {
        Position = UDim2.new(main.Position.X.Scale, main.Position.X.Offset, 1.2, 0),
        BackgroundTransparency = 1,
    })
    Aether.Tween(backdrop, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, { BackgroundTransparency = 1 })
    Aether.Tween(shadow, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, { ImageTransparency = 1 })

    task.delay(0.3, function() if main then main.Visible = false end end)
end

function Aether:Toggle()
    if self._isVisible then
        self:Minimize()
    else
        self._isVisible = true
        local main = self._main
        local backdrop = self._backdrop
        local shadow = self._shadow

        main.Visible = true
        main.Position = self._savedPosition or UDim2.fromScale(0.5, 0.5)
        main.BackgroundTransparency = 1

        Aether.Tween(backdrop, 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, { BackgroundTransparency = 0.6 })
        Aether.Tween(shadow, 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, { ImageTransparency = 0.4 })
        Aether.Tween(main, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out, {
            Position = self._savedPosition or UDim2.fromScale(0.5, 0.5),
            BackgroundTransparency = 0,
        })
    end
end

function Aether:Destroy()
    for _, conn in ipairs(self._connections) do
        conn:Disconnect()
    end
    if self._root then
        self._root:Destroy()
    end
end

