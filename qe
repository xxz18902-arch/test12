    }, btn)

    local listFrame = New("Frame", {
        BackgroundColor3 = C.Surface,
        BorderSizePixel = 0,
        Position = UDim2.new(0.48, 0, 0, 34),
        Size = UDim2.new(0.52, 0, 0, 0),
        ZIndex = 25,
        Visible = false,
        ClipsDescendants = true,
    }, frame)
    New("UICorner", { CornerRadius = UDim.new(0, 6) }, listFrame)
    New("UIStroke", { Color = C.Border, Thickness = 1 }, listFrame)
    New("UIListLayout", { SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 1) }, listFrame)
    New("UIPadding", { PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4) }, listFrame)

    for i, opt in ipairs(options) do
        local optBtn = New("TextButton", {
            BackgroundColor3 = C.Surface,
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Size = UDim2.new(1, -8, 0, 28),
            Position = UDim2.new(0, 4, 0, 0),
            Font = Enum.Font.Gotham,
            Text = opt,
            TextColor3 = (opt == selected) and C.AccentOrange or C.TextSecondary,
            TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left,
            ZIndex = 26,
            AutoButtonColor = false,
        }, listFrame)

        optBtn.MouseEnter:Connect(function()
            Aether.Tween(optBtn, 0.15, nil, nil, {BackgroundTransparency = 0.5})
            optBtn.TextColor3 = C.TextPrimary
        end)
        optBtn.MouseLeave:Connect(function()
            Aether.Tween(optBtn, 0.15, nil, nil, {BackgroundTransparency = 1})
            if opt ~= selected then optBtn.TextColor3 = C.TextSecondary end
        end)
        optBtn.MouseButton1Click:Connect(function()
            selected = opt
            btn.Text = selected
            open = false
            Aether.Tween(listFrame, 0.2, nil, nil, {Size = UDim2.new(0.52, 0, 0, 0)})
            Aether.Tween(arrow, 0.2, nil, nil, {Rotation = 0})
            Aether.Tween(btnStroke, 0.2, nil, nil, {Color = C.Border})
            task.delay(0.2, function() listFrame.Visible = false end)
            for _, child in ipairs(listFrame:GetChildren()) do
                if child:IsA("TextButton") then
                    child.TextColor3 = (child.Text == selected) and C.AccentOrange or C.TextSecondary
                end
            end
            pcall(callback, selected)
        end)
    end

    btn.MouseButton1Click:Connect(function()
        open = not open
        if open then
            listFrame.Visible = true
            local height = math.min(#options * 29 + 8, 220)
            Aether.Tween(listFrame, 0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, {Size = UDim2.new(0.52, 0, 0, height)})
            Aether.Tween(arrow, 0.2, nil, nil, {Rotation = 180})
            Aether.Tween(btnStroke, 0.2, nil, nil, {Color = C.AccentOrange})
        else
            Aether.Tween(listFrame, 0.2, nil, nil, {Size = UDim2.new(0.52, 0, 0, 0)})
            Aether.Tween(arrow, 0.2, nil, nil, {Rotation = 0})
            Aether.Tween(btnStroke, 0.2, nil, nil, {Color = C.Border})
            task.delay(0.2, function() listFrame.Visible = false end)
        end
    end)

    return {Set = function(v) selected = v; btn.Text = selected; pcall(callback, selected) end,
            Get = function() return selected end, Frame = frame}
end

function Elements.Button(parent, text, callback, style)
    callback = callback or function() end
    style = style or "primary"

    local btn = New("TextButton", {
        BackgroundColor3 = (style == "primary") and C.AccentOrange or (style == "danger") and C.Danger or C.Surface,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 34),
        Font = Enum.Font.GothamBold,
        Text = text,
        TextColor3 = C.TextPrimary,
        TextSize = 13,
        ZIndex = 15,
        AutoButtonColor = false,
    }, parent)
    New("UICorner", { CornerRadius = UDim.new(0, 6) }, btn)

    if style == "primary" then
        local gradient = New("UIGradient", {
            Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, C.AccentOrange),
                ColorSequenceKeypoint.new(1, C.AccentPurple),
            }),
            Rotation = 45,
        }, btn)
        btn.MouseEnter:Connect(function()
            Aether.Tween(gradient, 0.2, nil, nil, {Rotation = 90})
            Aether.Tween(btn, 0.2, nil, nil, {BackgroundColor3 = C.AccentPurple})
        end)
        btn.MouseLeave:Connect(function()
            Aether.Tween(gradient, 0.2, nil, nil, {Rotation = 45})
            Aether.Tween(btn, 0.2, nil, nil, {BackgroundColor3 = C.AccentOrange})
        end)
    else
        local stroke = New("UIStroke", { Color = (style == "danger") and C.Danger or C.Border, Thickness = 1 }, btn)
        btn.MouseEnter:Connect(function()
            Aether.Tween(btn, 0.2, nil, nil, {BackgroundColor3 = C.SurfaceHover})
            if stroke then Aether.Tween(stroke, 0.2, nil, nil, {Color = C.TextSecondary}) end
        end)
        btn.MouseLeave:Connect(function()
            Aether.Tween(btn, 0.2, nil, nil, {BackgroundColor3 = (style == "danger") and C.Danger or C.Surface})
            if stroke then Aether.Tween(stroke, 0.2, nil, nil, {Color = (style == "danger") and C.Danger or C.Border}) end
        end)
    end

    btn.MouseButton1Down:Connect(function(x, y)
        Aether.Tween(btn, 0.05, nil, nil, {Size = UDim2.new(1, 0, 0, 32)})
        ripple(btn, x, y)
    end)
    btn.MouseButton1Up:Connect(function()
        Aether.Tween(btn, 0.1, Enum.EasingStyle.Back, Enum.EasingDirection.Out, {Size = UDim2.new(1, 0, 0, 34)})
    end)
    btn.MouseButton1Click:Connect(function() pcall(callback) end)

    return {Frame = btn}
end

